{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug (Makefiles)",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ASTRAGLYPH_ENABLE_TESTS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release (Makefiles)",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ASTRAGLYPH_ENABLE_TESTS": "ON"
      }
    },
    {
      "name": "debug-ninja",
      "displayName": "Debug (Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ASTRAGLYPH_ENABLE_TESTS": "ON"
      }
    },
    {
      "name": "release-ninja",
      "displayName": "Release (Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ASTRAGLYPH_ENABLE_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "configuration": "Debug"
    },
    {
      "name": "release",
      "configurePreset": "release",
      "configuration": "Release"
    },
    {
      "name": "debug-ninja",
      "configurePreset": "debug-ninja",
      "configuration": "Debug"
    },
    {
      "name": "release-ninja",
      "configurePreset": "release-ninja",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug-ninja",
      "configurePreset": "debug-ninja",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
